[Desktop Entry]
Name=Swatchbook
GenericName=Style Binder
Comment=Craft and preview Markdown-powered style binders
Keywords=Markdown;Style;Swatch;Palette;Design;Canvas;Notes;Binder;
Keywords[es]=Markdown;Estilo;Muestra;Paleta;Diseño;Lienzo;Notas;Catálogo;
Exec=swatchbook %U
Icon=io.github.patricioaumedes.Swatchbook
Terminal=false
Type=Application
Categories=GTK;GNOME;Graphics;Utility;TextEditor;
StartupNotify=true
X-GNOME-UsesNotifications=true
Actions=NewCanvas;

[Desktop Action NewCanvas]
Name=New Canvas
Name[es]=Nuevo lienzo
Exec=swatchbook --new-canvas
